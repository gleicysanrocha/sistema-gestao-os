# Credenciais do Banco de Dados Cloud (Firebase)
# Substitua pelos dados do seu aplicativo web criado no console do Firebase.

VITE_FIREBASE_API_KEY=sua-api-key-do-firebase
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu-projeto-id
VITE_FIREBASE_STORAGE_BUCKET=seu-projeto-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=seu-sender-id
VITE_FIREBASE_APP_ID=seu-app-id
